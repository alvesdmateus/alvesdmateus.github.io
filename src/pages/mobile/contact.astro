---
import MobileLayout from '@layouts/MobileLayout.astro';
---

<MobileLayout
  title="Contact — Mateus Alves"
  description="Get in touch to start a project or discuss mobile development."
>
  <section class="contact">
    <div class="contact__container">
      <!-- Back link -->
      <a href="/mobile/" class="contact__back" aria-label="Back to portfolio">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back
      </a>

      <!-- Card -->
      <div class="contact__card">
        <div class="contact__header">
          <span class="contact__eyebrow">GET IN TOUCH</span>
          <h1 class="contact__title">Start a Project</h1>
          <p class="contact__subtitle">
            Tell me about what you're building. I'll get back to you within 24 hours.
          </p>
        </div>

        <!-- TODO: Replace YOUR_FORM_ID with your Forminit form ID -->
        <form
          action="https://forminit.com/f/YOUR_FORM_ID"
          method="POST"
          class="contact__form"
        >
          <div class="contact__field">
            <label for="fi-text-name" class="contact__label">Name</label>
            <input
              type="text"
              id="fi-text-name"
              name="fi-text-name"
              required
              autocomplete="name"
              placeholder="Your name"
              class="contact__input"
            />
          </div>

          <div class="contact__field">
            <label for="fi-sender-email" class="contact__label">Email</label>
            <input
              type="email"
              id="fi-sender-email"
              name="fi-sender-email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="contact__input"
            />
          </div>

          <div class="contact__field">
            <label for="fi-text-message" class="contact__label">Message</label>
            <textarea
              id="fi-text-message"
              name="fi-text-message"
              required
              rows="5"
              placeholder="Tell me about your project..."
              class="contact__input contact__textarea"
            ></textarea>
          </div>

          <button type="submit" class="contact__submit">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </section>
</MobileLayout>

<style>
  .contact {
    background-color: var(--mob-bg);
    padding: 7rem 2rem 5rem;
    min-height: 100dvh;
  }

  .contact__container {
    max-width: 36rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Back link */
  .contact__back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--mob-muted-bright);
    text-decoration: none;
    transition: color 150ms ease;
    width: fit-content;
  }

  .contact__back:hover {
    color: var(--mob-primary);
  }

  /* Card */
  .contact__card {
    background-color: var(--mob-card);
    border: 1px solid var(--mob-border);
    border-radius: 1.25rem;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Header */
  .contact__header {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact__eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--mob-primary);
    text-transform: uppercase;
  }

  .contact__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--mob-text);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .contact__subtitle {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--mob-muted-bright);
    margin: 0;
  }

  /* Form */
  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .contact__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--mob-muted-bright);
  }

  .contact__input {
    background-color: var(--mob-surface);
    border: 1px solid var(--mob-border);
    border-radius: 0.625rem;
    padding: 0.75rem 1rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--mob-text);
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .contact__input::placeholder {
    color: var(--mob-muted);
  }

  .contact__input:focus {
    outline: none;
    border-color: var(--mob-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 7rem;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    border-radius: 0.625rem;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    border: none;
    cursor: pointer;
    background-color: var(--mob-primary);
    color: #fff;
    box-shadow:
      0 0 14px rgba(37, 99, 235, 0.45),
      0 0 32px rgba(37, 99, 235, 0.2);
    transition: background-color 200ms ease, box-shadow 200ms ease;
    margin-top: 0.5rem;
  }

  .contact__submit:hover {
    background-color: var(--mob-primary-hover);
    box-shadow:
      0 0 20px rgba(37, 99, 235, 0.65),
      0 0 44px rgba(37, 99, 235, 0.3);
  }

  .contact__submit:focus-visible {
    outline: 2px solid var(--mob-primary);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .contact {
      padding: 6rem 1.25rem 3rem;
    }

    .contact__card {
      padding: 1.75rem 1.25rem;
    }
  }
</style>
