---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  image?: string;
  repoUrl?: string;
}

const { title, description, techStack, image, repoUrl, ...attrs } = Astro.props;

const githubStarIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`;

const badgeColors = [
  { bg: 'rgba(37,99,235,0.18)', text: '#60a5fa' },
  { bg: 'rgba(13,148,136,0.18)', text: '#2dd4bf' },
  { bg: 'rgba(124,58,237,0.18)', text: '#a78bfa' },
  { bg: 'rgba(249,115,22,0.18)', text: '#fb923c' },
];
---

<article class="app-card" {...attrs}>
  <!-- Phone screenshot -->
  <div class="app-card__screen">
    {
      image ? (
        <img
          src={image}
          alt={`${title} app screenshot`}
          class="app-card__img"
          width="260"
          height="480"
        />
      ) : (
        <div class="app-card__img-placeholder" aria-hidden="true">
          <span>📱</span>
        </div>
      )
    }
  </div>

  <!-- Info -->
  <div class="app-card__body">
    <h3 class="app-card__title">{title}</h3>
    <p class="app-card__desc">{description}</p>

    <ul class="app-card__badges" role="list" aria-label="Features">
      {
        techStack.map((badge, i) => {
          const color = badgeColors[i % badgeColors.length];
          return (
            <li
              class="app-card__badge"
              style={`background-color: ${color.bg}; color: ${color.text};`}
            >
              {badge}
            </li>
          );
        })
      }
    </ul>

    {repoUrl && (
      <a
        class="app-card__star"
        href={repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Star ${title} on GitHub`}
      >
        <span class="app-card__star-icon" set:html={githubStarIcon} />
        <span>Star on GitHub</span>
        <span class="app-card__star-glyph" aria-hidden="true">★</span>
      </a>
    )}
  </div>
</article>

<style>
  .app-card {
    background-color: var(--mob-card);
    border: 1px solid var(--mob-border);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .app-card:hover {
    border-color: var(--mob-border-bright);
    transform: translateY(-3px);
  }

  /* Screenshot area */
  .app-card__screen {
    width: 100%;
    height: 280px;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    background: linear-gradient(160deg, #0f1a2e 0%, #0b1121 100%);
    padding: 1.5rem 2rem 0;
    overflow: hidden;
  }

  .app-card__img {
    display: block;
    width: auto;
    max-width: 140px;
    height: 100%;
    max-height: 260px;
    object-fit: contain;
    object-position: bottom;
    border-radius: 0.75rem 0.75rem 0 0;
    box-shadow: 0 -4px 24px rgba(37, 99, 235, 0.12);
  }

  .app-card__img-placeholder {
    width: 140px;
    height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    opacity: 0.3;
  }

  /* Body */
  .app-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .app-card__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--mob-text);
    line-height: 1.25;
  }

  .app-card__desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--mob-muted-bright);
  }

  .app-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
  }

  .app-card__badge {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
  }

  .app-card__star {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--mob-muted-bright);
    text-decoration: none;
    border: 1px solid var(--mob-border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    width: fit-content;
    transition: border-color 200ms ease, color 200ms ease;
  }

  .app-card__star:hover {
    border-color: var(--mob-border-bright);
    color: var(--mob-text);
  }

  .app-card__star:focus-visible {
    outline: 2px solid var(--mob-primary);
    outline-offset: 2px;
  }

  .app-card__star-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    display: flex;
  }

  .app-card__star-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .app-card__star-glyph {
    margin-left: auto;
    color: #f59e0b;
    font-size: 0.75rem;
  }
</style>
