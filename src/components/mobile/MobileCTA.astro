---
import { getCollection } from 'astro:content';

const socialLinks = await getCollection('social');

const svgIcons: Record<string, string> = {
  github: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
};
---

<div class="cta-wrap">
  <!-- CTA card -->
  <section id="contact" class="cta">
    <div class="cta__container">
      <h2 class="cta__title">
        Ready to build your<br />
        <span class="cta__title-highlight">next app?</span>
      </h2>
      <p class="cta__subtitle">
        Whether it's a greenfield product or a performance rescue, let's talk about what we can build
        together.
      </p>
      <div class="cta__actions">
        <a href="/mobile/contact" class="cta__btn cta__btn--primary">
          Start a Project
        </a>
        <a
          href="https://github.com/alvesdmateus"
          class="cta__btn cta__btn--ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          View GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="mob-footer">
    <div class="mob-footer__container">
      <!-- Logo -->
      <div class="mob-footer__brand">
        <span class="mob-footer__logo-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="7" fill="var(--mob-primary)" opacity="0.15"/>
            <rect x="11" y="6" width="10" height="20" rx="2" stroke="var(--mob-primary)" stroke-width="1.8" fill="none"/>
            <rect x="14" y="22" width="4" height="1.5" rx="0.75" fill="var(--mob-primary)" opacity="0.6"/>
          </svg>
        </span>
        <span class="mob-footer__wordmark">Mobile Architect</span>
      </div>

      <!-- Copyright -->
      <p class="mob-footer__copy">
        &copy; {new Date().getFullYear()} Mateus Alves. All rights reserved.
      </p>

      <!-- Social -->
      <nav class="mob-footer__social" aria-label="Social links">
        {
          socialLinks.map((link) => (
            <a
              href={link.data.url}
              class="mob-footer__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.data.platform}
            >
              <span set:html={svgIcons[link.data.icon] ?? ''} />
            </a>
          ))
        }
      </nav>
    </div>
  </footer>
</div>

<style>
  /* CTA section */
  .cta {
    background-color: var(--mob-bg);
    padding: 5rem 2rem;
  }

  .cta__container {
    max-width: 44rem;
    margin-inline: auto;
    background-color: var(--mob-card);
    border: 1px solid var(--mob-border);
    border-radius: 1.25rem;
    padding: 3rem 2.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .cta__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--mob-text);
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .cta__title-highlight {
    color: var(--mob-primary);
  }

  .cta__subtitle {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--mob-muted-bright);
    max-width: 32rem;
    margin: 0;
  }

  .cta__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: 0.625rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 200ms ease, box-shadow 200ms ease;
  }

  .cta__btn--primary {
    background-color: var(--mob-primary);
    color: #fff;
    box-shadow:
      0 0 14px rgba(37, 99, 235, 0.45),
      0 0 32px rgba(37, 99, 235, 0.2);
  }

  .cta__btn--primary:hover {
    background-color: var(--mob-primary-hover);
    box-shadow:
      0 0 20px rgba(37, 99, 235, 0.65),
      0 0 44px rgba(37, 99, 235, 0.3);
  }

  .cta__btn--ghost {
    background-color: transparent;
    color: var(--mob-text);
    border: 1px solid var(--mob-border-bright);
  }

  .cta__btn--ghost:hover {
    border-color: var(--mob-primary);
    color: var(--mob-primary);
  }

  /* Footer */
  .mob-footer {
    background-color: var(--mob-surface);
    border-top: 1px solid var(--mob-border);
    padding: 2rem;
  }

  .mob-footer__container {
    max-width: 72rem;
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .mob-footer__brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .mob-footer__logo-icon {
    display: flex;
    width: 28px;
    height: 28px;
  }

  .mob-footer__logo-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .mob-footer__wordmark {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--mob-text);
    letter-spacing: -0.01em;
  }

  .mob-footer__copy {
    font-size: 0.8125rem;
    color: var(--mob-muted);
    margin: 0;
  }

  .mob-footer__social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mob-footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 0.5rem;
    color: var(--mob-muted-bright);
    border: 1px solid var(--mob-border);
    transition: color 150ms ease, border-color 150ms ease;
  }

  .mob-footer__social-link :global(svg) {
    width: 16px;
    height: 16px;
  }

  .mob-footer__social-link:hover {
    color: var(--mob-primary);
    border-color: var(--mob-primary);
  }

  @media (max-width: 640px) {
    .mob-footer__container {
      flex-direction: column;
      text-align: center;
    }

    .mob-footer__social {
      justify-content: center;
    }

    .cta__container {
      padding: 2rem 1.5rem;
    }
  }
</style>
