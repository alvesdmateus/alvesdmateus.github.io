---

<section id="stack" class="proficiency">
  <div class="proficiency__container">
    <!-- Header -->
    <div class="proficiency__header" data-reveal>
      <div class="proficiency__header-left">
        <span class="proficiency__eyebrow">ECOSYSTEM</span>
        <h2 class="proficiency__title">Technical Proficiency</h2>
      </div>
      <p class="proficiency__header-desc">
        Leveraging modern frameworks and cloud infrastructure to build resilient, offline-first mobile solutions.
      </p>
    </div>

    <!-- Cards -->
    <div class="proficiency__grid">
      {mobileSkills.map((skill, i) => (
        <div class="skill-card" data-reveal data-reveal-delay={i}>
          <span class="skill-card__icon" aria-hidden="true" set:html={icons[skill.icon] ?? icons.mobile} />
          <strong class="skill-card__name">{skill.name}</strong>
          <span class="skill-card__subtitle">{skill.subtitle}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .proficiency {
    background-color: var(--mob-surface);
    padding: 5rem 2rem;
    border-top: 1px solid var(--mob-border);
    border-bottom: 1px solid var(--mob-border);
  }

  .proficiency__container {
    max-width: 72rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Header */
  .proficiency__header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: end;
  }

  .proficiency__eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--mob-primary);
    margin-bottom: 0.625rem;
  }

  .proficiency__title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--mob-text);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .proficiency__header-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--mob-muted-bright);
    align-self: end;
  }

  /* Cards grid */
  .proficiency__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
  }

  .skill-card {
    background-color: var(--mob-card);
    border: 1px solid var(--mob-border);
    border-radius: 0.75rem;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    transition: border-color 200ms ease, transform 200ms ease;
  }

  .skill-card:hover {
    border-color: var(--mob-border-bright);
    transform: translateY(-2px);
  }

  .skill-card__icon {
    width: 28px;
    height: 28px;
    color: var(--mob-primary);
    display: block;
  }

  .skill-card__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .skill-card__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--mob-text);
    line-height: 1.2;
  }

  .skill-card__subtitle {
    font-size: 0.75rem;
    color: var(--mob-muted);
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .proficiency__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .proficiency__header {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .proficiency__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
