---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  liveUrl?: string;
  repoUrl?: string;
}

const { title, description, techStack, liveUrl, repoUrl } = Astro.props;

const githubStarIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`;
---

<article class="project-card">
  <h3 class="project-card__title">{title}</h3>
  <p class="project-card__description">{description}</p>

  <ul class="project-card__tech" role="list" aria-label={`Technologies used in ${title}`}>
    {
      techStack.map((tech) => (
        <li class="project-card__tag">{tech}</li>
      ))
    }
  </ul>

  <div class="project-card__links">
    {
      liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__link"
          aria-label={`View live demo of ${title}`}
        >
          Live Demo
        </a>
      )
    }
    {
      repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card__star"
          aria-label={`Star ${title} on GitHub`}
        >
          <span class="project-card__star-icon" set:html={githubStarIcon} />
          <span>Star on GitHub</span>
          <span class="project-card__star-glyph" aria-hidden="true">★</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .project-card {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-surface);
    transition: border-color var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    border-color: var(--color-primary);
  }

  .project-card__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-text);
    margin-block-end: var(--spacing-sm);
  }

  .project-card__description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-block-end: var(--spacing-md);
    flex-grow: 1;
  }

  .project-card__tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-block-end: var(--spacing-md);
  }

  .project-card__tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: var(--spacing-xs) var(--spacing-sm);
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-text-muted);
  }

  .project-card__links {
    display: flex;
    gap: var(--spacing-md);
  }

  .project-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .project-card__link:hover {
    color: var(--color-primary-hover);
  }

  .project-card__star {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.3rem 0.625rem;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .project-card__star:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .project-card__star:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .project-card__star-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    display: flex;
  }

  .project-card__star-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .project-card__star-glyph {
    color: #f59e0b;
    font-size: 0.7rem;
  }
</style>
