---
interface Props {
  title: string;
  description: string;
  techStack: string[];
  provider?: string[];
  image?: string;
  liveUrl?: string;
  repoUrl?: string;
}

const { title, description, techStack, provider = [], image, liveUrl, repoUrl } = Astro.props;

const inspectHref = liveUrl ?? repoUrl ?? '#';

const githubStarIcon = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`;

const providerColors: Record<string, { bg: string; text: string }> = {
  AWS: { bg: 'rgba(249,115,22,0.15)', text: '#f97316' },
  EKS: { bg: 'rgba(37,99,235,0.15)', text: '#60a5fa' },
  GCP: { bg: 'rgba(8,145,178,0.15)', text: '#22d3ee' },
  GKE: { bg: 'rgba(37,99,235,0.15)', text: '#60a5fa' },
  Hybrid: { bg: 'rgba(124,58,237,0.15)', text: '#a78bfa' },
  'On-Prem': { bg: 'rgba(75,85,99,0.2)', text: '#9ca3af' },
};
---

<article class="card">
  <div class="card__image-wrap">
    {
      image ? (
        <img src={image} alt={`${title} architecture diagram`} class="card__image" width="400" height="200" />
      ) : (
        <div class="card__image-placeholder" aria-hidden="true">
          <span class="card__image-icon">☁</span>
        </div>
      )
    }
    {
      provider.length > 0 && (
        <div class="card__providers" aria-label="Cloud providers">
          {provider.map((p) => {
            const colors = providerColors[p] ?? { bg: 'rgba(255,255,255,0.08)', text: '#94a3b8' };
            return (
              <span
                class="card__provider-badge"
                style={`background-color: ${colors.bg}; color: ${colors.text}`}
              >
                {p}
              </span>
            );
          })}
        </div>
      )
    }
  </div>

  <div class="card__body">
    <h3 class="card__title">{title}</h3>
    <p class="card__description">{description}</p>

    <ul class="card__tags" role="list" aria-label="Technologies used">
      {
        techStack.map((tech) => (
          <li class="card__tag">{tech}</li>
        ))
      }
    </ul>

    <div class="card__actions">
      <a
        href={inspectHref}
        class="card__link"
        target={inspectHref !== '#' ? '_blank' : undefined}
        rel={inspectHref !== '#' ? 'noopener noreferrer' : undefined}
        aria-label={`Inspect architecture for ${title}`}
      >
        Inspect Architecture <span aria-hidden="true">→</span>
      </a>
      {repoUrl && (
        <a
          class="card__star"
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Star ${title} on GitHub`}
        >
          <span class="card__star-icon" set:html={githubStarIcon} />
          <span>Star</span>
          <span class="card__star-glyph" aria-hidden="true">★</span>
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .card {
    background-color: var(--sre-card);
    border: 1px solid var(--sre-border);
    border-radius: 0.625rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 250ms ease, transform 250ms ease;
  }

  .card:hover {
    border-color: var(--sre-border-bright);
    transform: translateY(-2px);
  }

  /* Image */
  .card__image-wrap {
    position: relative;
    width: 100%;
    height: 11rem;
    overflow: hidden;
    background-color: #0d1117;
    flex-shrink: 0;
  }

  .card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0f1629 0%, #1a2540 100%);
  }

  .card__image-icon {
    font-size: 3rem;
    opacity: 0.2;
  }

  .card__providers {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    display: flex;
    gap: 0.25rem;
  }

  .card__provider-badge {
    font-family: var(--sre-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }

  /* Body */
  .card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--sre-text);
    line-height: 1.3;
  }

  .card__description {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--sre-muted-bright);
    flex: 1;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .card__tag {
    font-family: var(--sre-mono);
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--sre-muted-bright);
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
  }

  .card__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .card__link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sre-cyan);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .card__link:hover {
    color: #ffffff;
  }

  .card__star {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sre-muted-bright);
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.375rem;
    padding: 0.3rem 0.625rem;
    transition: border-color 150ms ease, color 150ms ease;
  }

  .card__star:hover {
    border-color: rgba(255, 255, 255, 0.25);
    color: #ffffff;
  }

  .card__star:focus-visible {
    outline: 2px solid var(--sre-cyan);
    outline-offset: 2px;
  }

  .card__star-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    display: flex;
  }

  .card__star-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .card__star-glyph {
    color: #f59e0b;
    font-size: 0.7rem;
  }
</style>
