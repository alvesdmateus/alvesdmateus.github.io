---
import BaseHead from '@components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const navLinks = [
  { label: 'Projects',    href: '#projects' },
  { label: 'Stack',       href: '#stack' },
  { label: 'Contact',     href: '#contact' },
];
---

<!doctype html>
<html lang="en" data-theme="mobile">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body class="mob-body">
    <a href="#main-content" class="sr-only focus:not-sr-only">Skip to main content</a>

    <header class="mob-header">
      <!-- Logo -->
      <a href="/" class="mob-header__logo" aria-label="Back to portfolio selection">
        <span class="mob-header__logo-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <rect width="20" height="20" rx="5" fill="#2563eb"/>
            <rect x="6" y="4" width="8" height="12" rx="2" fill="white" opacity="0.9"/>
            <rect x="8" y="14" width="4" height="1.5" rx="0.75" fill="#2563eb"/>
          </svg>
        </span>
        <span class="mob-header__logo-text">Mobile Architect</span>
      </a>

      <!-- Nav -->
      <nav class="mob-header__nav" aria-label="Mobile portfolio navigation">
        <ul class="mob-header__links" role="list">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="mob-header__link">{link.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Right: Hire Me + grid back -->
      <div class="mob-header__right">
        <a href="/mobile/contact" class="mob-header__hire">Hire Me</a>
        <a href="/" class="mob-header__grid-icon" aria-label="Back to selector">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="5" height="5" rx="1" fill="currentColor" opacity="0.6"/>
            <rect x="10" y="1" width="5" height="5" rx="1" fill="currentColor" opacity="0.6"/>
            <rect x="1" y="10" width="5" height="5" rx="1" fill="currentColor" opacity="0.6"/>
            <rect x="10" y="10" width="5" height="5" rx="1" fill="currentColor" opacity="0.6"/>
          </svg>
        </a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  [data-theme="mobile"] {
    --mob-bg: #0b1121;
    --mob-surface: #0f1629;
    --mob-card: #131c30;
    --mob-border: rgba(59, 130, 246, 0.12);
    --mob-border-bright: rgba(59, 130, 246, 0.28);
    --mob-text: #f1f5f9;
    --mob-muted: #64748b;
    --mob-muted-bright: #94a3b8;
    --mob-primary: #2563eb;
    --mob-primary-hover: #1d4ed8;
    --mob-teal: #0d9488;
    --mob-teal-light: #14b8a6;
  }
</style>

<style>
  .mob-body {
    background-color: var(--mob-bg);
    color: var(--mob-text);
    font-family: var(--font-body);
    min-height: 100dvh;
  }

  /* ===== Header ===== */
  .mob-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.75rem;
    background-color: rgba(11, 17, 33, 0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--mob-border);
  }

  /* Logo */
  .mob-header__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--mob-text);
    font-weight: 700;
    font-size: 0.9375rem;
    white-space: nowrap;
  }

  .mob-header__logo-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .mob-header__logo:hover .mob-header__logo-text {
    color: #ffffff;
  }

  /* Nav */
  .mob-header__nav {
    display: flex;
    align-items: center;
  }

  .mob-header__links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mob-header__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--mob-muted-bright);
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 0.375rem;
    transition: color 150ms ease, background-color 150ms ease;
  }

  .mob-header__link:hover {
    color: var(--mob-text);
    background-color: rgba(59, 130, 246, 0.08);
  }

  /* Right */
  .mob-header__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mob-header__hire {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background-color: var(--mob-primary);
    color: #ffffff;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 150ms ease, box-shadow 150ms ease;
    box-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
  }

  .mob-header__hire:hover {
    background-color: var(--mob-primary-hover);
    box-shadow: 0 0 18px rgba(59, 130, 246, 0.6);
  }

  .mob-header__grid-icon {
    color: var(--mob-muted);
    display: flex;
    align-items: center;
    padding: 0.25rem;
    border-radius: 0.25rem;
    transition: color 150ms ease;
  }

  .mob-header__grid-icon:hover {
    color: var(--mob-text);
  }

  @media (max-width: 767px) {
    .mob-header__nav {
      display: none;
    }
  }
</style>
